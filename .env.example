MICROSOFT_AUTH_FLOW=live
# Optional. In live mode TorchFlower can use the public Minecraft client id used by compatible Bedrock auth flows.
MICROSOFT_CLIENT_ID=
TOKEN_ENCRYPTION_KEY_B64=replace-with-base64-encoded-32-random-bytes
# Legacy fallback only. Prefer TOKEN_ENCRYPTION_KEY_B64.
TOKEN_ENCRYPTION_SECRET=
DATABASE_URL=sqlite://database/torchflower.sqlite
RUST_ENGINE_BIND=127.0.0.1:9080
LOG_LEVEL=info
TORCHFLOWER_API_KEY=replace-with-random-api-key
# Only needed when running the login example (cargo run -p torchflower-engine --example login).
# Set this to the Microsoft account e-mail you want to authenticate.
TORCHFLOWER_EXAMPLE_EMAIL=your@email.com
TORCHFLOWER_DEV_ALLOW_UNAUTH_API=false
TORCHFLOWER_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TORCHFLOWER_ALLOWED_SERVER_HOSTS=
TORCHFLOWER_DANGEROUS_LOG_AUTH_BODIES=false
BEDROCK_VALIDATE_ACCOUNT_ID=
BEDROCK_VALIDATE_SERVER_HOST=
BEDROCK_VALIDATE_SERVER_PORT=19132
BEDROCK_VALIDATE_DURATION_SECONDS=300
BEDROCK_TICK_SYNC_INTERVAL_MS=500
BEDROCK_RAKNET_TIMEOUT_MILLIS=60000

# -- Bot Pool ---------------------------------------------------------------
# Max simultaneous active Bedrock connections.
# Each connection uses roughly several MB RAM depending on server state.
TORCHFLOWER_MAX_BOTS=100

# Max bots authenticating at the same time.
# Microsoft rate-limits device-code auth. Keep this at 3 or below.
TORCHFLOWER_MAX_AUTH_CONCURRENT=3

# Milliseconds to wait between spawning each bot.
# Lower = faster ramp-up but higher risk of server rate-limit kick.
TORCHFLOWER_SPAWN_INTERVAL_MS=500

# -- Runtime ----------------------------------------------------------------
# Tokio worker thread count. Defaults to CPU core count.
TORCHFLOWER_WORKERS=4

# Thread stack size in bytes. 2MB is safe for bot workloads.
TORCHFLOWER_THREAD_STACK_BYTES=2097152

# -- Networking -------------------------------------------------------------
# Preferred compression algorithm: "zstd" or "zlib".
# zstd is faster if the server supports it.
TORCHFLOWER_COMPRESSION=zstd

# Packet buffer pool size. Usually TORCHFLOWER_MAX_BOTS * 4.
TORCHFLOWER_BUFFER_POOL_SIZE=400

# -- Database ---------------------------------------------------------------
# SQLite connection pool size.
TORCHFLOWER_DB_POOL_SIZE=8
