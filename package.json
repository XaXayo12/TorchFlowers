{
  "name": "rustrock-bedrock-discord-bot",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "build": "npm run build --workspace shared && npm run build --workspace server",
    "lint": "npm run lint --workspace server",
    "test": "npm run test --workspace server"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
